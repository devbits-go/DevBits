# Preferred for AWS (RDS/Postgres):
# DATABASE_URL=postgres://devbits:replace-with-strong-password@your-rds-endpoint:5432/devbits?sslmode=require
#
# Optional local fallback values (used if DATABASE_URL is unset):
POSTGRES_DB=devbits
POSTGRES_USER=devbits
POSTGRES_PASSWORD=replace-with-strong-password

DEVBITS_CORS_ORIGINS=https://devbits.app,https://www.devbits.app
DEVBITS_JWT_SECRET=replace-with-64+char-random-secret
DEVBITS_ADMIN_KEY=replace-with-base64-or-random-admin-key
DEVBITS_ADMIN_LOCAL_ONLY=0
DEVBITS_API_ADDR=0.0.0.0:8080
