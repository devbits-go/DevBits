#!/bin/sh
set -e

# pre-commit hook to scan staged files for common secret patterns
# Install by running: git config core.hooksPath .githooks

SECRETS_FOUND=0

echo "[pre-commit] scanning staged files for secrets..."

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$staged_files" ]; then
  exit 0
fi

for file in $staged_files; do
  # Skip binary files
  if git show :"$file" | head -c 8000 | grep -q "\x00"; then
    continue
  fi

  content=$(git show :"$file" 2>/dev/null || true)
  if [ -z "$content" ]; then
    continue
  fi

  # Patterns to detect
  echo "$content" | grep -E --quiet "-----BEGIN (RSA |OPENSSH |EC |PRIVATE )?PRIVATE KEY-----|-----BEGIN CERTIFICATE-----" && {
    echo "[pre-commit] ERROR: private key or certificate found in $file"; SECRETS_FOUND=1; }

  echo "$content" | grep -E --quiet '"private_key":|"client_email":|"type":\s*"service_account"' && {
    echo "[pre-commit] ERROR: service account credentials found in $file"; SECRETS_FOUND=1; }

  echo "$content" | grep -E --quiet 'google-services.json|GoogleService-Info.plist' && {
    echo "[pre-commit] WARNING: mobile service config file detected in $file"; SECRETS_FOUND=1; }

  echo "$file" | grep -E --quiet '\.(jks|p8|p12|key)$' && {
    echo "[pre-commit] ERROR: keystore file staged: $file"; SECRETS_FOUND=1; }

  # common API key patterns (basic heuristics)
  echo "$content" | grep -E --quiet 'AIza[0-9A-Za-z\-_]{35}' && {
    echo "[pre-commit] ERROR: Google API key detected in $file"; SECRETS_FOUND=1; }

  echo "$content" | grep -E --quiet 'password\"\s*:\s*\"|key_password|keystorePassword' && {
    echo "[pre-commit] ERROR: possible password value in $file"; SECRETS_FOUND=1; }
done

if [ "$SECRETS_FOUND" -ne 0 ]; then
  echo "\nPre-commit check failed: secrets detected in staged files. Remove secrets before committing or move them to ignored files / secret manager."
  exit 1
fi

echo "[pre-commit] OK"
exit 0
